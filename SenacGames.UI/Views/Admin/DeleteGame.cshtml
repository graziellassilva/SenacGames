@* Confirmar Exclusão de Game *@
@model GameDto
@{
    Layout = "_AdminLayout";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="form-senac text-center">
            <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 3rem;"></i>
            <h4 class="mt-3">Confirmar Exclusão</h4>
            <p class="text-muted-senac">Deseja realmente excluir o game abaixo?</p>
            e
            <div class="rounded p-3 my-3" style="background-color: var(--surface-container-high);">
                <h5 class="mb-1">@Model.Title</h5>
                <small class="text-muted-senac">@Model.CategoryName • @Model.ReleaseYear</small>
            </div>

            <div class="d-flex justify-content-center gap-3">
                <a asp-action="Games" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Cancelar
                </a>
                <form asp-action="DeleteGameConfirmed" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Excluir Game
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>