@* Cadastrar Novo Game — Design Stitch *@
@model GameFormViewModel
@{
    Layout = "_AdminLayout";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="form-senac">
            <form asp-action="CreateGame" method="post">
                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Title" class="form-label">Título do Game</label>
                        <input asp-for="Title" class="form-control" placeholder="Ex: God of War Ragnarök" required />
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label">Descrição</label>
                        <textarea asp-for="Description" class="form-control" rows="4"
                                  placeholder="Descreva o game..." required></textarea>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ReleaseYear" class="form-label">Ano de Lançamento</label>
                        <input asp-for="ReleaseYear" type="number" class="form-control"
                               min="1980" max="2030" required />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label">Categoria</label>
                        <select asp-for="CategoryId" class="form-select" required>
                            <option value="">Selecione uma categoria</option>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-12">
                        <label asp-for="CoverImageUrl" class="form-label">URL da Imagem de Capa</label>
                        <input asp-for="CoverImageUrl" class="form-control"
                               placeholder="https://exemplo.com/imagem.png" />
                    </div>

                    <div class="col-12">
                        <div class="form-check">
                            <input asp-for="IsFeatured" class="form-check-input" type="checkbox" />
                            <label asp-for="IsFeatured" class="form-check-label">
                                <i class="bi bi-star-fill text-warning"></i> Marcar como destaque
                            </label>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-between">
                    <a asp-action="Games" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary-senac">
                        <i class="bi bi-check-lg"></i> Cadastrar Game
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>