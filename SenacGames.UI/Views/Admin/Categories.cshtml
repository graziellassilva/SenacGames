@* Gerenciar Categorias — Design Stitch *@
@model IEnumerable<CategoryDto>
@{
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div></div>
    <a asp-action="CreateCategory" class="btn btn-primary-senac">
        <i class="bi bi-plus-circle"></i> Nova Categoria
    </a>
</div>

<div class="table-senac">
    <table class="table table-hover mb-0">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nome</th>
                <th>Games</th>
                <th class="text-end">Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var category in Model)
            {
                <tr>
                    <td class="text-muted">@category.Id</td>
                    <td class="fw-semibold">@category.Name</td>
                    <td><span class="badge bg-primary">@category.GameCount</span></td>
                    <td class="text-end">
                        <a asp-action="EditCategory" asp-route-id="@category.Id"
                               class="btn btn-sm btn-outline-primary me-1" title="Editar">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="DeleteCategory" asp-route-id="@category.Id"
                               class="btn btn-sm btn-outline-danger" title="Excluir">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>,